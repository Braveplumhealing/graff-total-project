# Copy to .claude/stripe.env (gitignored) and fill in. NEVER commit real keys.
# You create these in the Stripe dashboard; the agent only ever READS payment-link info,
# it never creates charges, payouts, or transfers.
STRIPE_SECRET_KEY=sk_live_xxx_or_sk_test_xxx
STRIPE_PUBLISHABLE_KEY=pk_live_xxx_or_pk_test_xxx
# Optional: your Calendly scheduling base URL
CALENDLY_URL=https://calendly.com/your-handle
