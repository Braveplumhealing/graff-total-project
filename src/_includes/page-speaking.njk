---
layout: base.njk
---
<div class="ph">
<div class="petals"></div>
<p class="ph-ey">{{ eyebrow }}</p>
<h1>{{ heading }}</h1>
<p class="ph-l">{{ lead | safe }}</p>
</div>
<section class="c"><div class="ci">
<p>{{ intro | safe }}</p>
<h2>Keynote Topics</h2>
<div class="tg">
{% for t in topics %}<div class="tc"><h3>{{ t.title | safe }}</h3><p>{{ t.body | safe }}</p></div>{% endfor %}
</div>
<h2>Formats &amp; Audiences</h2>
<ul>{% for f in formats %}<li>{{ f | safe }}</li>{% endfor %}</ul>
{% if quote %}<blockquote>{{ quote | safe }}</blockquote>{% endif %}
<h2>Book Johnny to Speak</h2>
<p>{{ book_text | safe }}</p>
<a href="contact.html" class="btn-p">Get in Touch &rarr;</a>
</div></section>
