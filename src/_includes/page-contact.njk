---
layout: base.njk
---
<div class="ph">
<div class="petals"></div>
<p class="ph-ey">{{ eyebrow }}</p>
<h1>{{ heading }}</h1>
<p class="ph-l">{{ lead | safe }}</p>
</div>
<section class="c"><div class="ci">
<p>{{ intro | safe }}</p>
{% if site.contact_phone %}<p style="background:var(--petal);border:1px solid rgba(194,99,126,.15);border-radius:12px;padding:1.1rem 1.4rem">📞 Prefer to talk? Call or text <strong>Rachel</strong> at <a href="tel:{{ site.contact_phone_tel }}">{{ site.contact_phone }}</a> to book some time with Johnny.</p>{% endif %}
<div class="form-box"><form id="cf" novalidate>
<div class="form-row"><div class="form-group"><label for="cf-name">Your Name</label><input id="cf-name" type="text" name="name" placeholder="First &amp; last name" autocomplete="name" required></div><div class="form-group"><label for="cf-email">Email Address</label><input id="cf-email" type="email" name="email" placeholder="you@email.com" autocomplete="email" required></div></div>
<div class="form-group"><label for="cf-topic">What brings you here?</label><select id="cf-topic" name="topic"><option value="">Select one...</option><option>1:1 Life Coaching</option><option>Reiki Healing Sessions</option><option>Healing Workshops</option><option>Weekend Retreat</option><option>Speaking / Keynote</option><option>Mediation / Facilitation</option><option>Podcast Guest</option><option>General Question</option></select></div>
<div class="form-group"><label for="cf-message">Your Message</label><textarea id="cf-message" name="message" placeholder="Share a little about where you are and what you&rsquo;re hoping for. There are no wrong answers." required></textarea></div>
<input type="checkbox" name="botcheck" tabindex="-1" autocomplete="off" style="display:none" aria-hidden="true">
<input type="hidden" name="subject" value="New message from braveplumhealing.org">
<button type="submit" class="form-submit">Send Your Message &rarr;</button>
<p id="cf-status" role="status" aria-live="polite" style="margin-top:.75rem;font-weight:400"></p>
</form></div>
<h2>What Happens Next</h2>
<ul>{% for s in next_steps %}<li>{{ s | safe }}</li>{% endfor %}</ul>
<p style="margin-top:1.5rem;font-style:italic;font-size:.9rem;color:var(--muted)">{{ confidential | safe }}</p>
</div></section>
<script>
(function(){
  const f = document.getElementById('cf');
  const status = document.getElementById('cf-status');
  if(!f) return;
  const endpoint = {{ site.contact_endpoint | dump | safe }};
  const provider = {{ site.contact_provider | dump | safe }};
  const email = {{ site.contact_email | dump | safe }};
  f.addEventListener('submit', async (e) => {
    e.preventDefault();
    if (f.botcheck && f.botcheck.checked) return; // honeypot tripped
    const btn = f.querySelector('.form-submit');

    // No endpoint configured yet → open the visitor's email app, pre-filled (works today).
    if (!endpoint) {
      const fd = new FormData(f);
      const subject = encodeURIComponent('Website enquiry — ' + (fd.get('topic') || 'General'));
      const body = encodeURIComponent(
        'Name: ' + (fd.get('name') || '') + '\nEmail: ' + (fd.get('email') || '') +
        '\nInterest: ' + (fd.get('topic') || '') + '\n\n' + (fd.get('message') || ''));
      window.location.href = 'mailto:' + email + '?subject=' + subject + '&body=' + body;
      status.style.color = '#7A3070';
      status.textContent = 'Opening your email app to send to ' + email + '…';
      return;
    }

    let url = endpoint;
    const data = new FormData(f);
    if (provider === 'web3forms') {           // endpoint holds the Web3Forms access key
      url = 'https://api.web3forms.com/submit';
      data.append('access_key', endpoint);
    }
    btn.textContent = 'Sending…'; btn.disabled = true; status.textContent = '';
    try {
      const res = await fetch(url, { method: 'POST', body: data, headers: { Accept: 'application/json' } });
      if (res.ok) {
        f.reset();
        btn.textContent = 'Sent ✓';
        status.style.color = '#7A3070';
        status.textContent = 'Thank you! Johnny will be in touch within 1–2 days.';
      } else {
        throw new Error('Request failed');
      }
    } catch (err) {
      btn.textContent = 'Send Your Message →'; btn.disabled = false;
      status.style.color = '#b3344f';
      status.textContent = 'Sorry — something went wrong. Please email braveplumhealing@outlook.com directly.';
    }
  });
})();
</script>
