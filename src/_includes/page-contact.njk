---
layout: base.njk
---
<div class="ph">
<div class="petals"></div>
<p class="ph-ey">{{ eyebrow }}</p>
<h1>{{ heading }}</h1>
<p class="ph-l">{{ lead | safe }}</p>
</div>
<section class="c"><div class="ci">
<p>{{ intro | safe }}</p>
<div class="form-box"><form id="cf" novalidate>
<div class="form-row"><div class="form-group"><label>Your Name</label><input type="text" placeholder="First &amp; last name" required></div><div class="form-group"><label>Email Address</label><input type="email" placeholder="you@email.com" required></div></div>
<div class="form-group"><label>What brings you here?</label><select><option value="">Select one...</option><option>1:1 Life Coaching</option><option>Reiki Healing Sessions</option><option>Healing Workshops</option><option>Weekend Retreat</option><option>Speaking / Keynote</option><option>Mediation / Facilitation</option><option>Podcast Guest</option><option>General Question</option></select></div>
<div class="form-group"><label>Your Message</label><textarea placeholder="Share a little about where you are and what you&rsquo;re hoping for. There are no wrong answers." required></textarea></div>
<button type="submit" class="form-submit">Send Your Message &rarr;</button>
</form></div>
<h2>What Happens Next</h2>
<ul>{% for s in next_steps %}<li>{{ s | safe }}</li>{% endfor %}</ul>
<p style="margin-top:1.5rem;font-style:italic;font-size:.9rem;color:var(--muted)">{{ confidential | safe }}</p>
</div></section>
<script>(function(){const f=document.getElementById('cf');if(f)f.addEventListener('submit',e=>{e.preventDefault();const b=f.querySelector('.form-submit');b.textContent='Sent ✓';b.disabled=true;const t=document.createElement('p');t.style='margin-top:.75rem;color:#7A3070;font-weight:400';t.textContent='Thank you! Johnny will be in touch within 1–2 days.';f.appendChild(t);});})();</script>
