---
layout: base.njk
---
<section class="ph" style="background:var(--plum);padding:calc(68px + 4rem) 2rem 3rem;text-align:center;position:relative;overflow:hidden">
  <div class="hero-glow"></div>
  <div style="position:relative;z-index:1;max-width:760px;margin:0 auto">
    <p class="eyebrow" style="justify-content:center">Brave Plum Journal</p>
    <h1 style="font-size:clamp(2.2rem,4.5vw,3.4rem)">{{ title }}</h1>
    {% if date %}<p class="sub" style="margin:1rem auto 0;color:rgba(253,232,238,.6)">{{ date | postDate }}</p>{% endif %}
  </div>
</section>

<article class="section" style="background:var(--cream)">
  <div class="si" style="max-width:740px">
    {% if image %}<img src="{{ image }}" alt="" style="width:100%;border-radius:14px;margin-bottom:2rem">{% endif %}
    <div class="post-body">{{ content | safe }}</div>
    <p style="margin-top:3rem"><a href="podcast.html" class="btn-p">&larr; Back</a></p>
  </div>
</article>

<style>
.post-body{font-size:1rem;font-weight:300;color:var(--text);line-height:1.85}
.post-body h2{margin:2rem 0 .8rem}.post-body h3{margin:1.6rem 0 .6rem;font-family:'Cormorant Garamond',serif;color:var(--plum)}
.post-body p{margin-bottom:1.2rem}.post-body a{color:var(--rose);text-decoration:underline}
.post-body ul,.post-body ol{margin:0 0 1.2rem 1.4rem}.post-body li{margin-bottom:.4rem}
.post-body blockquote{border-left:3px solid var(--blush);padding-left:1.2rem;font-style:italic;color:var(--muted);margin:1.5rem 0}
</style>
