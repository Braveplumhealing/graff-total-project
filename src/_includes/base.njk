C-11.2 -3 -16 -16.2 -13.12 -27C-10.56 -34.92 -4.48 -36 -3 -34C-1 -32.8 1 -32.8 3 -34C4.48 -36 10.56 -34.92 13.12 -27C16 -16.2 11.2 -3 0 -1Z" fill="url(#bpfalla)" fill-opacity=".8"/><path d="M0 -8C-1.2 -16 -1.2 -24 0 -31" stroke="#E293AC" stroke-width=".8" fill="none" stroke-opacity=".48" stroke-linecap="round"/></g><circle r="4.2" fill="#FDE8EE" fill-opacity=".95"/><path d="M0 -3.2Q0.39 -6.57 0 -11.96" stroke="#FDE8EE" stroke-width=".9" fill="none" stroke-linecap="round"/><circle cx="0" cy="-11.96" r="1.5" fill="#C4637E"/><path d="M2.35 -2.18Q4.01 -3.3 6.92 -6.42" stroke="#FDE8EE" stroke-width=".9" fill="none" stroke-linecap="round"/><circle cx="6.92" cy="-6.42" r="1.5" fill="#C4637E"/><path d="M3.19 -0.2Q4.83 -0.01 8.77 -0.54" stroke="#FDE8EE" stroke-width=".9" fill="none" stroke-linecap="round"/><circle cx="8.77" cy="-0.54" r="1.5" fill="#C4637E"/><path d="M2.81 1.54Q5.67 3.57 10.68 5.85" stroke="#FDE8EE" stroke-width=".9" fill="none" stroke-linecap="round"/><circle cx="10.68" cy="5.85" r="1.5" fill="#C4637E"/><path d="M1.48 2.83Q1.87 4.17 3.85 7.36" stroke="#FDE8EE" stroke-width=".9" fill="none" stroke-linecap="round"/><circle cx="3.85" cy="7.36" r="1.5" fill="#C4637E"/><path d="M-0.79 3.1Q-1.69 5.28 -2.5 9.76" stroke="#FDE8EE" stroke-width=".9" fill="none" stroke-linecap="round"/><circle cx="-2.5" cy="9.76" r="1.5" fill="#C4637E"/><path d="M-2.84 1.48Q-5.82 2.6 -10.28 5.35" stroke="#FDE8EE" stroke-width=".9" fill="none" stroke-linecap="round"/><circle cx="-10.28" cy="5.35" r="1.5" fill="#C4637E"/><path d="M-3.04 -0.98Q-4 -1.56 -7.43 -2.4" stroke="#FDE8EE" stroke-width=".9" fill="none" stroke-linecap="round"/><circle cx="-7.43" cy="-2.4" r="1.5" fill="#C4637E"/><path d="M-1.85 -2.61Q-3.29 -5.29 -6.55 -9.25" stroke="#FDE8EE" stroke-width=".9" fill="none" stroke-linecap="round"/><circle cx="-6.55" cy="-9.25" r="1.5" fill="#C4637E"/></g></g></svg>';
document.querySelectorAll('.petals').forEach(el=>{el.setAttribute('aria-hidden','true');if(el.children.length)return;for(let i=0;i<8;i++){const d=document.createElement('div');d.className='p';d.innerHTML=B;el.appendChild(d);}});
const nav=document.querySelector('nav');
if(nav)window.addEventListener('scroll',()=>nav.style.boxShadow=window.scrollY>20?'0 4px 32px rgba(61,26,61,.35)':'',{passive:true});
const tg=document.querySelector('.nav-toggle'),links=document.querySelector('.nav-links');
if(tg&&links)tg.addEventListener('click',()=>{const open=links.classList.toggle('open');tg.setAttribute('aria-expanded',open?'true':'false');});
})();
</script>
{% if site.goatcounter %}
<script data-goatcounter="https://{{ site.goatcounter }}.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
<script>
// Booking-funnel events: count clicks OUT to Stripe / Calendly / the phone line.
// No cookies, no personal data — just "someone took a booking step".
document.addEventListener('click',function(e){
  var a=e.target.closest('a[href]');if(!a||!window.goatcounter||!window.goatcounter.count)return;
  var h=a.href;
  if(/buy\.stripe\.com/.test(h))window.goatcounter.count({path:'event-pay-click',title:'Stripe link clicked',event:true});
  else if(/calendly\.com/.test(h))window.goatcounter.count({path:'event-book-click',title:'Calendly clicked',event:true});
  else if(h.indexOf('tel:')===0)window.goatcounter.count({path:'event-phone-click',title:'Phone tapped',event:true});
});
</script>
{% endif %}
</body>
</html>
