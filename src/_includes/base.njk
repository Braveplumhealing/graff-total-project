<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<base href="{{ '/' | url }}">
{% set pageTitle = title or "Brave Plum Healing — Mediation, Workshops & Retreats with Johnny" %}
{% set pageDesc = description or "A warm, gentle sanctuary for healing and growth. Mediation, healing workshops, team building, and weekend retreats with Johnny." %}
<title>{{ pageTitle }}</title>
<meta name="description" content="{{ pageDesc }}">
<link rel="canonical" href="{{ site.url }}{{ page.url }}">
<meta name="theme-color" content="#3D1A3D">
<meta property="og:type" content="website">
<meta property="og:site_name" content="Brave Plum Healing">
<meta property="og:title" content="{{ pageTitle }}">
<meta property="og:description" content="{{ pageDesc }}">
<meta property="og:url" content="{{ site.url }}{{ page.url }}">
<meta name="twitter:card" content="summary">
<link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;1,300;1,400&family=Jost:wght@300;400;500&display=swap" rel="stylesheet">
<link rel="icon" href="assets/favicon.svg" type="image/svg+xml">
<link rel="stylesheet" href="assets/style.css">
<script type="application/ld+json">
{"@context":"https://schema.org","@type":"LocalBusiness","name":"Brave Plum Healing",
"url":"{{ site.url }}","telephone":"{{ site.contact_phone_tel }}","email":"{{ site.contact_email }}",
"founder":{"@type":"Person","name":"Johnny Graf"},
"description":"Mediation, healing workshops, team building, weekend retreats, speaking, and life coaching — with Reiki woven through."}
</script>
</head>
<body>
<a class="skip-link" href="{{ page.url }}#main">Skip to content</a>
{% include "nav.njk" %}
<main id="main">
{{ content | safe }}
</main>
{% include "footer.njk" %}
<script>
(function(){
const nav=document.querySelector('nav');
if(nav)window.addEventListener('scroll',()=>nav.style.boxShadow=window.scrollY>20?'0 4px 32px rgba(61,26,61,.35)':'',{passive:true});
const tg=document.querySelector('.nav-toggle'),links=document.querySelector('.nav-links');
if(tg&&links)tg.addEventListener('click',()=>{const open=links.classList.toggle('open');tg.setAttribute('aria-expanded',open?'true':'false');});
})();
</script>
{% if site.goatcounter %}
<script data-goatcounter="https://{{ site.goatcounter }}.goatcounter.com/count" async src="https://gc.zgo.at/count.js"></script>
<script>
// Booking-funnel events: count clicks OUT to Stripe / Calendly / the phone line.
// No cookies, no personal data — just "someone took a booking step".
document.addEventListener('click',function(e){
  var a=e.target.closest('a[href]');if(!a||!window.goatcounter||!window.goatcounter.count)return;
  var h=a.href;
  if(/buy\.stripe\.com/.test(h))window.goatcounter.count({path:'event-pay-click',title:'Stripe link clicked',event:true});
  else if(/calendly\.com/.test(h))window.goatcounter.count({path:'event-book-click',title:'Calendly clicked',event:true});
  else if(h.indexOf('tel:')===0)window.goatcounter.count({path:'event-phone-click',title:'Phone tapped',event:true});
});
</script>
{% endif %}
</body>
</html>
