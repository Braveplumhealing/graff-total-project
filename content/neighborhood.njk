<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8"><meta name="viewport" content="width=device-width,initial-scale=1.0">
<title>The Neighborhood — Brave Plum Operations</title>
<meta name="description" content="Live operations watchtower for Brave Plum Healing: site health, the agent team, recent activity, and the self-verifying governance ledger.">
<meta name="robots" content="noindex">
<link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;1,300;1,400&family=Jost:wght@300;400;500&family=IBM+Plex+Mono:wght@300;400&display=swap" rel="stylesheet">
<style>
:root{--plum:#3D1A3D;--plum2:#4A2149;--rose:#C4637E;--blush:#F2B8C6;--petal:#FDE8EE;--cream:#FDF5F0;--sage:#7FA97F;--gold:#C49A3A;--ink:rgba(253,232,238,.72);--faint:rgba(253,232,238,.38);--line:rgba(242,184,198,.16);--card:rgba(253,232,238,.055);--ease:cubic-bezier(.16,1,.3,1)}
*{box-sizing:border-box;margin:0;padding:0}
body{background:var(--plum);color:var(--ink);font-family:'Jost',sans-serif;font-size:15px;line-height:1.6;min-height:100vh}
a{color:var(--blush);text-decoration:none}a:hover{color:var(--petal)}
.wrap{max-width:1100px;margin:0 auto;padding:0 1.4rem}
/* header */
header{position:relative;overflow:hidden;padding:3.2rem 0 2.2rem;background:radial-gradient(ellipse 75% 90% at 50% -20%,rgba(196,99,126,.30) 0%,transparent 62%)}
.crest{display:flex;align-items:center;gap:1rem}
.crest svg{width:52px;height:52px;flex-shrink:0}
.ey{font-size:.64rem;letter-spacing:.3em;text-transform:uppercase;color:var(--blush);opacity:.8}
h1{font-family:'Cormorant Garamond',serif;font-weight:300;font-size:clamp(2rem,4.5vw,3rem);color:var(--petal);line-height:1.08}
h1 em{font-style:italic;color:var(--blush)}
.tag{margin-top:.5rem;font-weight:300;color:var(--faint);max-width:56ch}
.homelink{position:absolute;top:1.2rem;right:1.4rem;font-size:.7rem;letter-spacing:.14em;text-transform:uppercase;color:var(--faint)}
/* sections */
section{padding:1.6rem 0}
h2{font-family:'Cormorant Garamond',serif;font-weight:400;font-size:1.45rem;color:var(--petal);margin-bottom:.2rem}
.sub{font-size:.8rem;color:var(--faint);margin-bottom:1.1rem}
/* status lanterns */
.lanterns{display:grid;grid-template-columns:repeat(4,1fr);gap:.9rem}
.lantern{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:1.05rem 1.15rem;transition:transform .3s var(--ease)}
.lantern:hover{transform:translateY(-3px)}
.ll{font-size:.6rem;letter-spacing:.18em;text-transform:uppercase;color:var(--faint);margin-bottom:.35rem}
.lv{display:flex;align-items:center;gap:.55rem;font-family:'Cormorant Garamond',serif;font-size:1.28rem;color:var(--petal)}
.lamp{width:11px;height:11px;border-radius:50%;background:var(--faint);flex-shrink:0;box-shadow:0 0 0 0 transparent;transition:all .4s}
.lamp.ok{background:var(--sage);box-shadow:0 0 12px rgba(127,169,127,.65)}
.lamp.bad{background:#D06A6A;box-shadow:0 0 12px rgba(208,106,106,.6)}
.lamp.wait{background:var(--gold);animation:pulse 1.6s infinite}
@keyframes pulse{50%{opacity:.45}}
.ln{font-size:.72rem;color:var(--faint);margin-top:.3rem;min-height:1.1em}
/* the street */
.rogers{background:linear-gradient(135deg,rgba(196,99,126,.16),rgba(122,48,112,.22));border:1px solid rgba(242,184,198,.3);border-radius:16px;padding:1.5rem 1.6rem;display:flex;gap:1.3rem;align-items:flex-start;margin-bottom:1rem}
.rogers svg{width:56px;height:56px;flex-shrink:0}
.rname{font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--petal)}
.rrole{font-size:.62rem;letter-spacing:.2em;text-transform:uppercase;color:var(--blush);opacity:.75;margin-bottom:.4rem}
.rsay{font-weight:300;color:var(--ink);max-width:62ch}
.street{display:grid;grid-template-columns:repeat(7,1fr);gap:.7rem}
.house{background:var(--card);border:1px solid var(--line);border-top:3px solid var(--rose);border-radius:12px;padding:.85rem .8rem;transition:transform .3s var(--ease),background .25s}
.house:hover{transform:translateY(-4px);background:rgba(253,232,238,.1)}
.hn{font-family:'IBM Plex Mono',monospace;font-size:.74rem;color:var(--petal)}
.hr{font-size:.68rem;font-weight:300;color:var(--faint);line-height:1.45;margin-top:.25rem}
/* two-column */
.cols{display:grid;grid-template-columns:1fr 1fr;gap:1.4rem;align-items:start}
.panel{background:var(--card);border:1px solid var(--line);border-radius:16px;padding:1.3rem 1.4rem}
.feed li{display:flex;gap:.75rem;padding:.55rem 0;border-bottom:1px solid rgba(242,184,198,.08);font-size:.83rem;list-style:none}
.feed li:last-child{border-bottom:none}
.dot{width:8px;height:8px;border-radius:50%;margin-top:.42rem;flex-shrink:0;background:var(--rose)}
.dot.run-ok{background:var(--sage)}.dot.run-bad{background:#D06A6A}.dot.run-wait{background:var(--gold)}
.fm{color:var(--ink)}.ft{font-size:.68rem;color:var(--faint)}
/* ledger */
.seal{display:inline-flex;align-items:center;gap:.6rem;border:1px solid var(--line);border-radius:100px;padding:.45rem 1.05rem;font-size:.76rem;margin-bottom:1rem;background:rgba(61,26,61,.35)}
.seal .lamp{width:9px;height:9px}
.entry{font-family:'IBM Plex Mono',monospace;font-size:.72rem;padding:.55rem 0;border-bottom:1px solid rgba(242,184,198,.08);color:var(--ink)}
.entry:last-child{border-bottom:none}
.entry .who{color:var(--blush)}
.entry .hash{color:var(--faint);font-size:.64rem;word-break:break-all}
.chip{display:inline-block;border-radius:100px;padding:.05rem .55rem;font-size:.6rem;letter-spacing:.08em;margin-left:.4rem;border:1px solid var(--line)}
.t0{color:var(--sage)}.t1{color:var(--gold)}.t2{color:#D06A6A}
/* covenant + doors */
.covenant{border:1px dashed rgba(242,184,198,.28);border-radius:14px;padding:1.1rem 1.3rem;font-size:.83rem;font-weight:300;color:var(--faint)}
.covenant strong{color:var(--blush);font-weight:400}
.doors{display:grid;grid-template-columns:repeat(3,1fr);gap:.9rem}
.door{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:1rem 1.1rem;font-size:.8rem}
.door b{display:block;font-family:'Cormorant Garamond',serif;font-weight:500;font-size:1.05rem;color:var(--petal);margin-bottom:.25rem}
footer{padding:2.2rem 0 2.6rem;font-size:.7rem;color:rgba(253,232,238,.25)}
.err{color:#E09A9A;font-size:.78rem}
/* what you can ask */
.askgrid{display:grid;grid-template-columns:repeat(3,1fr);gap:.9rem}
.ask{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:1rem 1.1rem;display:flex;flex-direction:column;gap:.35rem;transition:transform .3s var(--ease)}
.ask:hover{transform:translateY(-3px)}
.ask b{font-family:'Cormorant Garamond',serif;font-weight:500;font-size:1.08rem;color:var(--petal)}
.ask i{font-style:italic;font-size:.78rem;color:var(--faint);font-weight:300}
.ask a{margin-top:auto;font-size:.68rem;letter-spacing:.12em;text-transform:uppercase}
/* waiting on you */
.want{display:flex;gap:.7rem;align-items:flex-start;padding:.6rem 0;border-bottom:1px solid rgba(242,184,198,.08);font-size:.83rem}
.want:last-child{border-bottom:none}
.want .em{font-size:1rem;line-height:1.4}
.want a{font-size:.68rem;letter-spacing:.1em;text-transform:uppercase;white-space:nowrap;margin-left:auto;padding-left:.8rem}
@media(max-width:880px){.lanterns{grid-template-columns:1fr 1fr}.street{grid-template-columns:repeat(3,1fr)}.cols{grid-template-columns:1fr}.doors{grid-template-columns:1fr}.askgrid{grid-template-columns:1fr}}
@media(prefers-reduced-motion:reduce){*{animation:none!important;transition:none!important}}
</style>
</head>
