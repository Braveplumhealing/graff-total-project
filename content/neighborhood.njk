  <p class="sub">All of them lead to the same governed neighborhood — and the same warm reply.</p>
  <div class="doors">
    <div class="door"><b>Tap it</b>The <i>Ask now</i> buttons above — no setup, works today, tracked from ask to answer.</div>
    <div class="door"><b>Email it</b>rogers@braveplumhealing.com → he files it and gets to work. One 10-min connect: docs/EMAIL-SETUP.md.</div>
    <div class="door"><b>Text it</b>From Telegram: /status · /audit · /publish · /task &lt;anything&gt;. Setup: docs/TELEGRAM-SETUP.md.</div>
    <div class="door"><b>Write it</b>The private <a href="../admin/index.html">/admin editor</a> — drafts stay private until you press Publish.</div>
  </div>
</section>

<section>
  <div class="covenant"><strong>The covenant:</strong> agents never move money, disburse funds, delete data, change permissions, touch secrets, create accounts, or accept terms. Those doors open only to Johnny. Everything else is logged, reviewed, and reversible.</div>
</section>

</main>
<footer><div class="wrap">Brave Plum Healing · The Neighborhood watchtower · data refreshes on each visit · <span id="stamp"></span></div></footer>

<script>
(async function(){
const REPO='Braveplumhealing/graff-total-project';
const API='https://api.github.com/repos/'+REPO;
const RAW='https://raw.githubusercontent.com/'+REPO+'/main';
const $=id=>document.getElementById(id);
const lamp=(id,state)=>{const el=$( 'lamp-'+id);el.className='lamp '+state;};
const ago=iso=>{const s=(Date.now()-new Date(iso))/1e3;if(s<90)return 'just now';const m=s/60;if(m<90)return Math.round(m)+' min ago';const h=m/60;if(h<36)return Math.round(h)+' hr ago';return Math.round(h/24)+' days ago';};
$('stamp').textContent='rendered '+new Date().toLocaleString();

// --- live site check (same-origin fetch of the homepage) ---
try{
  const r=await fetch('../index.html',{cache:'no-store'});
  lamp('site',r.ok?'ok':'bad');$('v-site').textContent=r.ok?'Up':'HTTP '+r.status;
}catch(e){lamp('site','bad');$('v-site').textContent='Unreachable';}

// --- GitHub: workflow runs, commits, open PRs/tasks ---
const gh=p=>fetch(API+p,{headers:{Accept:'application/vnd.github+json'}}).then(r=>r.ok?r.json():Promise.reject(r.status));
try{
  const runs=(await gh('/actions/runs?per_page=15')).workflow_runs||[];
  const pick=n=>runs.find(r=>r.name===n);
  const show=(key,run)=>{ if(!run){lamp(key,'bad');$('v-'+key).textContent='no runs';return;}
    const ok=run.conclusion==='success', pend=!run.conclusion;
    lamp(key,pend?'wait':ok?'ok':'bad');
    $('v-'+key).textContent=pend?'running…':ok?'Healthy':run.conclusion;
    $('n-'+key).textContent=ago(run.updated_at);};
  show('deploy',pick('Build & deploy site to GitHub Pages'));
  show('tests',pick('Tests (unit · chaos · scale)'));

  const [prs,tasks]=await Promise.all([gh('/pulls?state=open'),gh('/issues?labels=mr-rogers&state=open')]);
  const openAsks=tasks.filter(t=>!t.pull_request);
  const wl=[];
  prs.forEach(p=>wl.push('<div class="want"><span class="em">🔍</span><div>Review waiting: <b>'+esc(p.title)+'</b></div><a href="'+esc(p.html_url)+'">Review →</a></div>'));
  openAsks.forEach(t=>wl.push('<div class="want"><span class="em">🌸</span><div>Open ask: <b>'+esc(t.title)+'</b></div><a href="'+esc(t.html_url)+'">Open →</a></div>'));
  $('waitlist').innerHTML=wl.length?wl.join(''):'<div class="want"><span class="em">✨</span><div class="fm">No open reviews or asks — the neighborhood is all caught up.</div></div>';
  const waiting=prs.length+openAsks.length;
  lamp('gate',waiting?'wait':'ok');
  $('v-gate').textContent=waiting? (waiting+' item'+(waiting>1?'s':'')) :'All clear';
  $('n-gate').textContent=waiting?(prs.length+' PR · '+tasks.filter(t=>!t.pull_request).length+' task'):'nothing needs your review';
  $('rogers-note').textContent=waiting?('Right now '+waiting+' item'+(waiting>1?'s are':' is')+' waiting for your eyes.'):'Nothing is waiting on you right now.';

  const commits=await gh('/commits?per_page=5');
  const feed=[];
  commits.forEach(c=>feed.push({t:c.commit.author.date,dot:'',html:'<div class="fm">'+esc(c.commit.message.split('\n')[0])+'</div><div class="ft">commit · '+ago(c.commit.author.date)+'</div>'}));
  runs.slice(0,5).forEach(r=>feed.push({t:r.updated_at,dot:r.conclusion==='success'?'run-ok':r.conclusion?'run-bad':'run-wait',html:'<div class="fm">'+esc(r.name)+'</div><div class="ft">'+(r.conclusion||r.status)+' · '+ago(r.updated_at)+'</div>'}));
  feed.sort((a,b)=>new Date(b.t)-new Date(a.t));
  $('feed').innerHTML=feed.slice(0,8).map(f=>'<li><span class="dot '+f.dot+'"></span><div>'+f.html+'</div></li>').join('');
}catch(e){
  $('feed').innerHTML='<li><span class="dot run-bad"></span><div class="fm err">GitHub data unavailable right now ('+esc(String(e))+'). It refreshes on your next visit.</div></li>';
  ['deploy','tests','gate'].forEach(k=>{lamp(k,'bad');$('v-'+k).textContent='—';});
}

// --- one-tap asks: every [data-ask] opens a pre-addressed note to Mr Rogers ---
document.querySelectorAll('[data-ask]').forEach(a=>{
  a.href='https://github.com/'+REPO+'/issues/new?labels=mr-rogers&title='+encodeURIComponent(a.dataset.ask)+'&body='+encodeURIComponent(a.dataset.body||'');
  a.target='_blank';a.rel='noopener';
});

// --- the signature: verify the HIBT hash chain right here in the browser ---
function esc(s){return String(s).replace(/[&<>"']/g,c=>({'&':'&amp;','<':'&lt;','>':'&gt;','"':'&quot;',"'":'&#39;'}[c]));}
async function sha256(str){const b=await crypto.subtle.digest('SHA-256',new TextEncoder().encode(str));return 'sha256:'+[...new Uint8Array(b)].map(x=>x.toString(16).padStart(2,'0')).join('');}
try{
  const txt=await (await fetch(RAW+'/audit/log.jsonl',{cache:'no-store'})).text();
  const lines=txt.trim().split('\n').filter(Boolean);
  let prev='GENESIS',ok=true,prevSeq=null;
  for(const line of lines){
    const e=JSON.parse(line);
    const sealed={...e};delete sealed.hash;
    if(e.prev_hash!==prev)ok=false;
    if(await sha256(JSON.stringify(sealed))!==e.hash)ok=false;
    if(Number.isFinite(e.seq)&&Number.isFinite(prevSeq)&&e.seq!==prevSeq+1)ok=false;
    if(Number.isFinite(e.seq))prevSeq=e.seq;
    prev=e.hash;
  }
  lamp('chain',ok?'ok':'bad');
  $('v-chain').textContent=ok?('Chain intact — '+lines.length+' entries, verified in your browser just now'):'INTEGRITY FAILURE — the record has been altered';
  $('ledger').innerHTML=lines.slice(-6).reverse().map(l=>{const e=JSON.parse(l);
    return '<div class="entry"><span class="who">'+esc(e.actor||'?')+'</span> → '+esc(e.action||'')+
    '<span class="chip t'+(e.tier??1)+'">tier '+(e.tier??'?')+'</span><br>'+esc(e.target||'')+
    '<br><span class="hash">'+esc(String(e.hash||'').slice(0,34))+'… · '+esc(String(e.ts||'').slice(0,10))+'</span></div>';}).join('');
}catch(e){
  lamp('chain','bad');$('v-chain').textContent='Ledger unreachable right now';
  $('ledger').innerHTML='<div class="err">Could not load audit/log.jsonl ('+esc(String(e))+').</div>';
}
})();
</script>
</body>
</html>
